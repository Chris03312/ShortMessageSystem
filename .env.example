# ─── Example Server Configuration ────────────────────────────────────────
# Copy this file to .env and configure your settings

# Server Configuration
SERVER_IP= "example of server ip address"
SERVER_PORT= "example of server port number"
NODE_ENV= "example of node environment (development or production)"

# CORS Settings
ALLOWED_ORIGIN=*

# API Endpoints (relative paths)
ENDPOINT_SEND_SMS= "example of send sms api endpoint"
ENDPOINT_CANCEL="example of cancel sms api endpoint"
ENDPOINT_CHECK_GATEWAY= "example of check gateway api endpoint"
ENDPOINT_COUNT_LOGS= "example of count logs api endpoint"
ENDPOINT_USERS= "example of users api endpoint"
ENDPOINT_LOGIN= "example of login api endpoint"
ENDPOINT_SERVER_INFO= "example of server info api endpoint"

# Storage Keys
STORAGE_KEY_ID= "example of storage key for ID"
STORAGE_KEY_NAME= "example of storage key for name"
STORAGE_KEY_NUMBER= "example of storage key for number"
STORAGE_KEY_FORM_DATA= "example of storage key for form data"
STORAGE_KEY_CURRENT_USER= "example of storage key for current user"
